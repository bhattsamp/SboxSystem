# Production environment template for InfyPOS backend.
# Copy this file to ".env" on the server and fill in real values.
# Do NOT commit the real ".env" file.

NODE_ENV=production
PORT=5000

# MongoDB (local instance on the same server)
MONGO_URI=mongodb://localhost:27017/infypos

# JWT - generate a fresh secret on the server with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=2097152

# Frontend URL (for CORS + Socket.io) - must match the public domain exactly
CLIENT_URL=https://sboxsystem.crmespitravels.in

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=200
